<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".SOLOREELApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SOLOREEL"
        android:usesCleartextTraffic="true"
        tools:targetApi="35">
        <activity
            android:name=".CrashActivity"
            android:exported="false"
            android:theme="@style/Theme.SOLOREEL" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.SOLOREEL">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Payment checkout runs in a Chrome Custom Tab (real browser engine,
                 not an embedded WebView) — payment gateways are notoriously
                 unreliable inside WebViews (cookie/storage restrictions, popup
                 handling, fraud-detection heuristics that specifically target
                 them). The server redirects here once payment completes. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="soloreel" android:host="payment-complete" />
            </intent-filter>
        </activity>

        <!-- AdMob App ID — this is Google's public TEST App ID. Swap for the real
             one from your AdMob console before release (see ADMOB_SETUP.md). -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" />
    </application>
</manifest>
