RewriteEngine On

# Ensure Authorization header is passed to PHP
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Redirect /api/payout/initialize to /api/payout/initialize.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(initialize|payout)$ initialize.php [L,QSA]

# Account Resolution Alias (/api/payout/resolve, etc)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(resolve|resolve-account|verify-account)$ ../bank/resolve.php [L,QSA]
